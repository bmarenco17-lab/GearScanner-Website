# Copy this file to .env and fill in your values

# ── Supabase (Settings -> API Keys in your Supabase project) ──
# Project URL is already set in src/supabaseClient.js.
# Only the anon/public key needs to go here — it's safe to expose
# in frontend code (Row Level Security protects your data).
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Admin panel ─────────────────────────────────────────────
# Backend API base URL (leave blank to use same-origin)
VITE_API_URL=

# Shared secret required by the backend's
# POST /api/admin/create-department endpoint. Must match
# ADMIN_API_KEY in web-app/backend/.env.
# NOTE: this value ends up in the frontend bundle, so it only
# provides light protection — see setup notes for hardening.
VITE_ADMIN_API_KEY=choose-a-long-random-string
