# Copy this file to .env and fill in your key
# Get your API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
PORT=3001

# CORS — set to your deployed frontend URL in production
FRONTEND_URL=https://app.gearscanner.net

# ── Supabase (Settings -> API Keys in your Supabase project) ──
# Project URL
SUPABASE_URL=https://vgjfkjahzirrlgdlegbn.supabase.co
# service_role secret key — admin-only, NEVER expose to the frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin panel access ─────────────────────────────────────────
# Shared secret the admin panel sends as the `x-admin-key` header
# when creating department accounts. Make this a long random string.
ADMIN_API_KEY=choose-a-long-random-string
