# Supabase project credentials (Project Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# EmailJS credentials (Account > General / Email Services / Email Templates)
# The Email Template's "To Email" field controls where contact form
# submissions are delivered (e.g. gearscanner@outlook.com).
VITE_EMAILJS_SERVICE_ID=your-service-id
VITE_EMAILJS_TEMPLATE_ID=your-template-id
VITE_EMAILJS_PUBLIC_KEY=your-public-key
